APP_NAME=DriftGuard AI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
USE_DATABASE=true
DATABASE_URL=sqlite:///./storage/driftguard.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSION_EXPIRE_HOURS=24
MAX_UPLOAD_SIZE_MB=25
ENABLE_OPTIONAL_LLM=false
DEFAULT_REASONING_MODE=local_only
LOG_LEVEL=INFO

